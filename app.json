{
  "expo": {
    "name": "PritechTaskMeriton",
    "slug": "PritechTaskMeriton",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "pritechtask",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC",
      "dark": {
        "backgroundColor": "#0B1120"
      }
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Pritech Task Manager schedules local reminders when a task is due. No push server or fitness data is used."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization",
      [
        "expo-notifications",
        {
          "defaultChannel": "task-reminders",
          "color": "#2563EB",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAFC",
          "dark": {
            "backgroundColor": "#0B1120"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
